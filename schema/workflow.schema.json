{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FlowFFmpeg Workflow",
  "type": "object",
  "required": ["input", "output"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1, "default": 1},
    "input": {"type": "string", "minLength": 1},
    "output": {"type": "string", "minLength": 1},
    "nodes": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {"const": "trim"},
              "start": {"type": "number", "minimum": 0},
              "duration": {"type": "number", "exclusiveMinimum": 0}
            }
          },
          {
            "type": "object",
            "required": ["type", "height"],
            "properties": {
              "type": {"const": "scale"},
              "width": {"type": "integer"},
              "height": {"type": "integer", "minimum": 1}
            }
          },
          {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {"const": "fps"},
              "value": {"type": "number", "exclusiveMinimum": 0}
            }
          },
          {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {"const": "volume"},
              "value": {"type": "number", "minimum": 0}
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {"const": "codec"},
              "video": {"type": "string"},
              "audio": {"type": "string"}
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
